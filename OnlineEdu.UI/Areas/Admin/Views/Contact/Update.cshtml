@model UpdateContactDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "İletişim Güncelle";

}

<form method="post">
    <input type="hidden" asp-for="ContactId" />
    <label asp-for="MapUrl" >Maps Url</label>
    <input asp-for="MapUrl" class="form-control" />
    <br />
    <label asp-for="Address">Adres</label>
    <textarea asp-for="Address" class="form-control" rows="5" ></textarea>

    <br />
    <label asp-for="Email">Email</label>
    <input asp-for="Email" class="form-control" />
    <br />
    <label asp-for="Phone">Phone</label>
    <input asp-for="Phone" class="form-control" />
    <br />
    <button type="submit" class="btn btn-outline-primary">Ekle</button>
</form>
