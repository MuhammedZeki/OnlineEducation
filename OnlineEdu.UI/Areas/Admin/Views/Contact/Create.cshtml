@model CreateContactDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "İletişim Ekle";

}

<form method="post">
    <label asp-for="MapUrl"></label>
    <input asp-for="MapUrl" class="form-control" />
    <br />
    <label asp-for="Address"></label>
    <textarea asp-for="Address" class="form-control" rows="5" ></textarea>
    <br />
    <label asp-for="Email"></label>
    <input asp-for="Email" class="form-control" />
    <br />
    <label asp-for="Phone"></label>
    <input asp-for="Phone" class="form-control" />
    <br />
    <button type="submit" class="btn btn-outline-primary">Ekle</button>
</form>
