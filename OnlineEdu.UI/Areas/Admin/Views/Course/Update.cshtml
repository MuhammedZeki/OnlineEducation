@model UpdateCourseDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kurs Güncelle";

}

<form method="post" asp-controller="Course" asp-action="Update">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="CourseId" />
    <label asp-for="CourseName"></label>
    <input asp-for="CourseName" class="form-control" />
    <span asp-validation-for="CourseName" class="text-danger"></span>
    <br />
    <label asp-for="ImageUrl"></label>
    <input asp-for="ImageUrl" class="form-control" />
    <span asp-validation-for="ImageUrl" class="text-danger"></span>
    <br />
    <label asp-for="Price"></label>
    <input asp-for="Price" class="form-control" />
    <span asp-validation-for="Price" class="text-danger"></span>
    <br />
    <div class="form-check">
        <input type="checkbox" asp-for="IsShown" class="form-check-input" />
        <label asp-for="IsShown" class="form-check-label"></label>
    </div>
    <br />
    <label asp-for="CourseCategoryId">Kategoriler</label>
    <select asp-for="CourseCategoryId" asp-items="ViewBag.Categories" class="form-control">
        <option value="">Kategori Seçiniz</option>
    </select>
    <span asp-validation-for="CourseCategoryId" class="text-danger"></span>
    <br />
    <button type="submit" class="btn btn-outline-primary">Güncelle</button>
</form>
